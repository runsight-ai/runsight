[2K[1A[2K[1A[2K[1A[2K[1A[2K[1A[2K[1A[2K[1A[2K[1A[2K[G  $ echo "=== E2E Mechanical Anti-Pattern Check ==="
    echo ""

    # 3. Error Swallowing — .catch(() => {}) / .catch(() => false)
    echo "--- #3 Error Swallowing ---"
    grep -rn '\.catch(\s*() =>' apps/gui/e2e/ --include='*.ts'
    --include='*.js' --include='*.cy.*' | grep -v node_modules | grep -v '//
    justified'

    # 4. Always-Passing — assertion that can never fail
    echo "--- #4 Always-Passing ---"
    grep -rn -E 'toBeGreaterThanOrEqual\(0\)|should\(.*(gte|greaterThan).*0\)'
     apps/gui/e2e/ --include='*.ts' --include='*.js' --include='*.cy.*'

    # 5. Boolean Trap — toBeTruthy on non-boolean values (Locator,
    ElementHandle, selector result)
    echo "--- #5 Boolean Trap ---"
    grep -rn -E
    'expect\(.*\)\.toBeTruthy\(\)|should\(.*(be\.truthy|be\.true)\)'
    apps/gui/e2e/ --include='*.spec.*' --include='*.test.*' --include='*.cy.*'
     | grep -v -E
    '\.(ok|isVisible|isChecked|isDisabled|isEnabled|isEditable|isHidden)\(\)'

    # 6. Conditional Bypass — expect inside if(isVisible)
    echo "--- #6 Conditional Bypass ---"
    grep -rn -E "if.*(isVisible|is\(.*:visible.*\))" apps/gui/e2e/
    --include='*.spec.*' --include='*.test.*' --include='*.cy.*'

    # 7. Raw DOM — document.querySelector in spec/test files
    echo "--- #7 Raw DOM in specs ---"
    grep -rn 'document\.querySelector' apps/gui/e2e/ --include='*.spec.*'
    --include='*.test.*' --include='*.cy.*'

    # 12. Hard-coded Timeout — waitForTimeout / cy.wait(number)
    echo "--- #12 Hard-coded Timeout ---"
    grep -rn -E 'waitForTimeout|cy\.wait\(\d' apps/gui/e2e/ --include='*.ts'
    --include='*.js' --include='*.cy.*'

    # 13b. Network dependency — goto/visit without route/intercept setup
    nearby
    echo "--- #13b Missing Network Mock ---"
    grep -rn -E 'page\.goto|cy\.visit' apps/gui/e2e/ --include='*.spec.*'
    --include='*.test.*' --include='*.cy.*' | grep -v
    'route\.\|intercept\|mock' | head -20

    echo ""
    echo "=== Done ===" 0ms

