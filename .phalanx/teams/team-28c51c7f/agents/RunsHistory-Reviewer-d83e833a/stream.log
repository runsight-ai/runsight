    #!/bin/bash
    while true; do
      phalanx agent-result RunsHistory-UI-9716e7ee > /dev/null 2>&1
      UI_DONE=$?
      phalanx agent-result RunsHistory-E2E-636cbc54 > /dev/null 2>&1
      E2E_DONE=$?

      if [ $UI_DONE -eq 0 ] && [ $E2E_DONE -eq 0 ]; then
        echo "Both coders are done!"
        break
      fi

      echo "Waiting for coders... UI: $UI_DONE, E2E: $E2E_DONE"
      sleep 5
    done
    EOF
    chmod +x wait_for_coders.sh
    ./wait_for_coders.sh 8ms

