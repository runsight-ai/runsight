    // ─── Run Complete
    ───────────────────────────────────────────────────────────────

    test.describe('Run Complete', () => {
      test.beforeEach(async ({ page }) => {
        const workflow = makeLiveExecutionWorkflow();
        await stubBaseAPIs(page, { workflow });

        // Ensure Math.random() > 0.1 always succeeds in the local simulation
        await page.addInitScript(() => {
          Math.random = () => 0.99;
        });
      });

      test('Verify summary toast appears with cost and duration info', async
    ({ page }) => {
        await page.goto('/workflows/test-wf-1');
        await page.getByRole('button', { name: 'Run', exact: true }).click();

        // Wait for completion
        await expect(page.getByText(/Read-only during
    execution/i)).not.toBeVisible({ timeout: 15000 });

        // Verify summary toast appears with cost and duration info
        await expect(page.getByText(/Run complete/i)).toBeVisible();
        await expect(page.getByText(/\$/)).toBeVisible();
        await expect(page.getByText(/s\b/)).toBeVisible();

        await page.screenshot({ path: 'e2e-screenshots/run-complete-toast.png'
     });
      });

      test('Run button changes to Run Again after successful completion',
    async ({ page }) => {
        await page.goto('/workflows/test-wf-1');
        await page.getByRole('button', { name: 'Run', exact: true }).click();

        // Wait for completion
        await expect(page.getByText(/Read-only during
    execution/i)).not.toBeVisible({ timeout: 15000 });

        // Verify Run button text changes to 'Run Again'
        await expect(page.getByRole('button', { name: /Run Again/i
    })).toBeVisible();

        await page.screenshot({ path:
    'e2e-screenshots/run-complete-button.png' });
      });

      test('bottom panel shows run complete banner', async ({ page }) => {
        await page.goto('/workflows/test-wf-1');
        await page.getByRole('button', { name: 'Run', exact: true }).click();

        // Wait for completion
        await expect(page.getByText(/Read-only during
    execution/i)).not.toBeVisible({ timeout: 15000 });

        // Verify bottom panel has 'Run complete' or 'completed' text
        await expect(page.getByText(/Run
    complete|completed/i).last()).toBeVisible();
      });

      test('nodes show final static state after completion', async ({ page })
    => {
        await page.goto('/workflows/test-wf-1');
        await page.getByRole('button', { name: 'Run', exact: true }).click();

        // Wait for completion
        await expect(page.getByText(/Read-only during
    execution/i)).not.toBeVisible({ timeout: 15000 });

        // Verify nodes are visible with completed status
        const node1 = page.locator('.react-flow__node').filter({ hasText:
    'Analyze Code' });
        await expect(node1.getByText('Completed', { exact: true
    })).toBeVisible();

        // Verify no pulse animation class on completed nodes
        await expect(node1.locator('.animate-pulse,
    .pulse')).not.toBeVisible();
      });

      test('Run Again resets and re-executes', async ({ page }) => {
        await page.goto('/workflows/test-wf-1');
        await page.getByRole('button', { name: 'Run', exact: true }).click();

        // Wait for completion
        await expect(page.getByText(/Read-only during
    execution/i)).not.toBeVisible({ timeout: 15000 });

        // Click 'Run Again'
        await page.getByRole('button', { name: /Run Again/i }).click();

        // Verify execution restarts (Running state appears again)
        await expect(page.getByRole('button', { name: /Running/i
    })).toBeVisible();
        await expect(page.getByText(/Read-only during
    execution/i)).toBeVisible();
      });
    });
    EOF 0ms

