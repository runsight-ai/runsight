---
// Landing page — outside Starlight, standalone layout
// Design tokens from /observatory/marketing-design-system/
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Runsight — YAML-first workflow engine for AI agents</title>
  <meta name="description" content="Design agent workflows in YAML. Commit to Git. Track cost per run. Evaluate with built-in assertions. Open source, self-hosted.">

  <!-- Fonts: Satoshi (marketing) + JetBrains Mono (code) -->
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin>
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,600,700,900&display=swap" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
</head>

<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- ═══════════════════════════════════════════
       NAVIGATION
       ═══════════════════════════════════════════ -->
  <header>
    <nav class="nav" aria-label="Main">
      <a href="/" class="nav__logo" aria-label="Runsight home">
        <span class="nav__logo-mark">
          <svg viewBox="0 0 32 32" fill="none" aria-hidden="true"><rect width="32" height="32" rx="7" fill="#F59E0B"/><circle cx="16" cy="8.5" r="3" fill="#fff"/><circle cx="8" cy="22" r="3" fill="#fff" opacity="0.8"/><circle cx="24" cy="22" r="3" fill="#fff" opacity="0.8"/><circle cx="16" cy="17" r="2" fill="#fff" opacity="0.6"/><line x1="16" y1="11.5" x2="16" y2="15" stroke="#fff" stroke-width="1.8" stroke-linecap="round"/><line x1="14.5" y1="18.5" x2="9.5" y2="20.5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" opacity="0.7"/><line x1="17.5" y1="18.5" x2="22.5" y2="20.5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" opacity="0.7"/></svg>
        </span>
        Runsight
      </a>

      <ul class="nav__links" id="nav-links" role="list">
        <li><a href="#features" class="nav__link">Features</a></li>
        <li><a href="#how-it-works" class="nav__link">How It Works</a></li>
        <li><a href="/docs/" class="nav__link">Docs</a></li>
      </ul>

      <div class="nav__actions">
        <a href="https://github.com/runsight-ai/runsight" class="btn-ghost btn-sm">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          GitHub
        </a>
        <a href="#get-started" class="btn-install"><span class="prompt">$</span> uvx runsight</a>
      </div>

      <button class="nav__toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-links">
        <span></span>
      </button>
    </nav>
  </header>

  <main id="main-content">

    <!-- ═══════════════════════════════════════════
         SECTION 1: HERO
         ═══════════════════════════════════════════ -->
    <section class="hero" aria-labelledby="hero-heading">
      <div class="container">
        <div class="hero__grid">
          <div class="hero__text" data-reveal>
            <div class="badge">
              <span class="badge__dot"></span>
              Open Source
            </div>
            <h1 id="hero-heading" class="hero__headline">
              YAML workflows.<br><em>Git-native AI agents.</em>
            </h1>
            <p class="hero__sub">
              Design agent workflows in YAML. Commit to Git. Track cost per run. Evaluate with built-in assertions. Pause or kill agents mid-flight.
            </p>
            <div class="hero__actions">
              <a href="#get-started" class="btn-install btn-lg"><span class="prompt">$</span> uvx runsight</a>
              <a href="https://github.com/runsight-ai/runsight" class="btn-ghost">View on GitHub</a>
            </div>
          </div>

          <!-- Hero visual: Canvas ↔ YAML duality -->
          <div class="hero__visual" data-reveal>
            <div class="duality-pair">
              <!-- Canvas representation -->
              <div class="code-window code-window--canvas">
                <div class="code-chrome">
                  <span class="code-chrome__dot"></span>
                  <span class="code-chrome__dot"></span>
                  <span class="code-chrome__dot"></span>
                  <span class="code-chrome__filename">canvas</span>
                </div>
                <div class="canvas-nodes">
                  <div class="canvas-node canvas-node--running">
                    <div class="canvas-node__stripe canvas-node__stripe--green"></div>
                    <div class="canvas-node__body">
                      <span class="canvas-node__icon">&#9655;</span>
                      <span class="canvas-node__label">Research</span>
                      <span class="canvas-node__badge">$0.03</span>
                    </div>
                    <span class="canvas-node__type">LINEAR</span>
                  </div>
                  <svg class="canvas-edge" viewBox="0 0 40 32" aria-hidden="true">
                    <line x1="20" y1="0" x2="20" y2="24" stroke="currentColor" stroke-width="1.5"/>
                    <polygon points="15,24 20,32 25,24" fill="currentColor"/>
                  </svg>
                  <div class="canvas-node">
                    <div class="canvas-node__stripe canvas-node__stripe--amber"></div>
                    <div class="canvas-node__body">
                      <span class="canvas-node__icon">&#9670;</span>
                      <span class="canvas-node__label">Review</span>
                      <span class="canvas-node__badge">$0.02</span>
                    </div>
                    <span class="canvas-node__type">GATE</span>
                  </div>
                  <svg class="canvas-edge" viewBox="0 0 40 32" aria-hidden="true">
                    <line x1="20" y1="0" x2="20" y2="24" stroke="currentColor" stroke-width="1.5"/>
                    <polygon points="15,24 20,32 25,24" fill="currentColor"/>
                  </svg>
                  <div class="canvas-node">
                    <div class="canvas-node__stripe"></div>
                    <div class="canvas-node__body">
                      <span class="canvas-node__icon">&#9724;</span>
                      <span class="canvas-node__label">Publish</span>
                    </div>
                    <span class="canvas-node__type">CODE</span>
                  </div>
                </div>
              </div>

              <div class="duality-sync" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 16l-4-4 4-4"/><path d="M17 8l4 4-4 4"/><line x1="3" y1="12" x2="21" y2="12"/></svg>
              </div>

              <!-- YAML output -->
              <div class="code-window">
                <div class="code-chrome">
                  <span class="code-chrome__dot"></span>
                  <span class="code-chrome__dot"></span>
                  <span class="code-chrome__dot"></span>
                  <span class="code-chrome__filename">workflow.yaml</span>
                </div>
                <pre><code><span class="tk-key">version</span><span class="tk-punct">:</span> <span class="tk-str">"1.0"</span>
<span class="tk-key">blocks</span><span class="tk-punct">:</span>
  <span class="tk-key">research</span><span class="tk-punct">:</span>
    <span class="tk-key">type</span><span class="tk-punct">:</span> <span class="tk-str">linear</span>
    <span class="tk-key">soul_ref</span><span class="tk-punct">:</span> <span class="tk-str">analyst</span>
  <span class="tk-key">review</span><span class="tk-punct">:</span>
    <span class="tk-key">type</span><span class="tk-punct">:</span> <span class="tk-str">gate</span>
    <span class="tk-key">soul_ref</span><span class="tk-punct">:</span> <span class="tk-str">editor</span>
    <span class="tk-key">eval_key</span><span class="tk-punct">:</span> <span class="tk-str">research</span>
    <span class="tk-key">pass</span><span class="tk-punct">:</span> <span class="tk-str">publish</span>
    <span class="tk-key">fail</span><span class="tk-punct">:</span> <span class="tk-str">research</span>
  <span class="tk-key">publish</span><span class="tk-punct">:</span>
    <span class="tk-key">type</span><span class="tk-punct">:</span> <span class="tk-str">code</span>

<span class="tk-key">workflow</span><span class="tk-punct">:</span>
  <span class="tk-key">name</span><span class="tk-punct">:</span> <span class="tk-str">Research Pipeline</span>
  <span class="tk-key">entry</span><span class="tk-punct">:</span> <span class="tk-str">research</span></code></pre>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="hero__scroll-cue" aria-hidden="true">
        <svg viewBox="0 0 16 16"><polyline points="4,6 8,10 12,6" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECTION 2: METRICS BAR
         ═══════════════════════════════════════════ -->
    <section class="metrics-bar section--compact" aria-label="Platform highlights" data-reveal>
      <div class="container">
        <div class="metrics-bar__item">
          <span class="metrics-bar__value">YAML</span>
          <span class="metrics-bar__label">Filesystem-native workflows</span>
        </div>
        <div class="metrics-bar__item">
          <span class="metrics-bar__value">Git</span>
          <span class="metrics-bar__label">Every save is a commit</span>
        </div>
        <div class="metrics-bar__item">
          <span class="metrics-bar__value">$0.00</span>
          <span class="metrics-bar__label">Per-run cost tracking</span>
        </div>
        <div class="metrics-bar__item">
          <span class="metrics-bar__value">100%</span>
          <span class="metrics-bar__label">Open source</span>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECTION 3: THE DUALITY (Primary Feature)
         ═══════════════════════════════════════════ -->
    <section class="feature-duality section--standard" id="features" aria-labelledby="duality-heading">
      <div class="container">
        <div class="feature-duality__header" data-reveal>
          <span class="section-label">THE DUALITY</span>
          <h2 id="duality-heading" class="section-title">Canvas and YAML. Same state.</h2>
          <p class="section-description">
            Two views of the same workflow. Edit YAML in the Monaco editor — the canvas updates. Move nodes on the canvas — the YAML stays clean. Commit the YAML to Git like any other code.
          </p>
        </div>

        <div class="feature-duality__grid" data-reveal-stagger>
          <div class="code-window code-window--wide">
            <div class="code-chrome">
              <span class="code-chrome__dot"></span>
              <span class="code-chrome__dot"></span>
              <span class="code-chrome__dot"></span>
              <span class="code-chrome__filename">terminal</span>
            </div>
            <pre><code><span class="tk-cmt"># Your workflow is a file on disk</span>
<span class="tk-punct">$</span> cat custom/workflows/research-pipeline.yaml

<span class="tk-key">version</span><span class="tk-punct">:</span> <span class="tk-str">"1.0"</span>
<span class="tk-key">blocks</span><span class="tk-punct">:</span>
  <span class="tk-key">research</span><span class="tk-punct">:</span>
    <span class="tk-key">type</span><span class="tk-punct">:</span> <span class="tk-str">linear</span>
    <span class="tk-key">soul_ref</span><span class="tk-punct">:</span> <span class="tk-str">analyst</span>

<span class="tk-cmt"># Git diff it like any other code</span>
<span class="tk-punct">$</span> git diff workflow.yaml
<span style="color:hsl(0,60%,60%)">- soul_ref: analyst</span>
<span style="color:hsl(142,60%,60%)">+ soul_ref: senior-analyst</span>
<span style="color:hsl(142,60%,60%)">+ budget:</span>
<span style="color:hsl(142,60%,60%)">+   max_cost: 0.50</span>

<span class="tk-cmt"># Commit and run</span>
<span class="tk-punct">$</span> git add . && git commit -m <span class="tk-str">"upgrade analyst soul, add cost cap"</span>
<span class="tk-punct">$</span> runsight run research-pipeline</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECTION 4: BENTO FEATURE GRID
         ═══════════════════════════════════════════ -->
    <section class="features-bento section--standard" aria-labelledby="features-heading">
      <div class="container">
        <div class="features-bento__header" data-reveal>
          <span class="section-label">CAPABILITIES</span>
          <h2 id="features-heading" class="section-title">Ship agents like you ship code.</h2>
        </div>

        <div class="bento-grid" data-reveal-stagger>
          <!-- Featured: Cost tracking -->
          <div class="bento-card bento-card--featured">
            <div class="bento-card__icon">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="9" cy="9" r="7"/><path d="M9 5v4l3 2"/></svg>
            </div>
            <h3 class="bento-card__title">Per-run cost tracking</h3>
            <p class="bento-card__desc">
              Every block, every run — tracked to the cent. Set hard budget caps that kill execution before overspend. No more surprise bills.
            </p>
            <div class="bento-card__code">
<span class="tk-key">budget</span><span class="tk-punct">:</span>
  <span class="tk-key">max_cost</span><span class="tk-punct">:</span> <span class="tk-val">2.00</span>
  <span class="tk-key">max_tokens</span><span class="tk-punct">:</span> <span class="tk-val">50000</span>

<span class="tk-cmt"># Run output</span>
<span class="tk-punct">▶</span> research   <span class="tk-str">$0.032</span>   1.2s
<span class="tk-punct">▶</span> review     <span class="tk-str">$0.018</span>   0.8s
<span class="tk-punct">─────────────────────</span>
  Total<span class="tk-punct">:</span> <span class="tk-str">$0.050</span>  Cap<span class="tk-punct">:</span> <span class="tk-val">$2.00</span></div>
          </div>

          <!-- Card: Built-in evaluation -->
          <div class="bento-card">
            <div class="bento-card__icon">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="4,9 7,12 14,5"/><rect x="1" y="1" width="16" height="16" rx="2"/></svg>
            </div>
            <h3 class="bento-card__title">Built-in eval framework</h3>
            <p class="bento-card__desc">
              Assertions on every block output. Transform hooks for structured extraction. Regression testing across runs.
            </p>
          </div>

          <!-- Card: Runtime control -->
          <div class="bento-card">
            <div class="bento-card__icon">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="4" height="12" rx="1"/><rect x="11" y="3" width="4" height="12" rx="1"/></svg>
            </div>
            <h3 class="bento-card__title">Pause and kill mid-run</h3>
            <p class="bento-card__desc">
              Stop a running agent before it wastes your budget. Pause execution, inspect state, then resume or kill.
            </p>
          </div>

          <!-- Card: Git-native -->
          <div class="bento-card">
            <div class="bento-card__icon">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="9" cy="4" r="2"/><circle cx="9" cy="14" r="2"/><circle cx="15" cy="9" r="2"/><line x1="9" y1="6" x2="9" y2="12"/><path d="M10.5 5.5 L13.5 7.5"/></svg>
            </div>
            <h3 class="bento-card__title">Git-diffable workflows</h3>
            <p class="bento-card__desc">
              Every workflow is a YAML file in your repo. Branch, review, and merge agent changes like any other code.
            </p>
          </div>

          <!-- Card: Self-hosted -->
          <div class="bento-card">
            <div class="bento-card__icon">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="14" height="4" rx="1"/><rect x="2" y="8" width="14" height="4" rx="1"/><circle cx="13" cy="4" r="1" fill="currentColor"/><circle cx="13" cy="10" r="1" fill="currentColor"/><line x1="9" y1="14" x2="9" y2="17"/><line x1="6" y1="17" x2="12" y2="17"/></svg>
            </div>
            <h3 class="bento-card__title">Self-hosted. Your keys.</h3>
            <p class="bento-card__desc">
              Runs on your machine. Your API keys. Your models. Nothing leaves your network unless you want it to.
            </p>
          </div>

          <!-- Card: Loops & sub-workflows -->
          <div class="bento-card">
            <div class="bento-card__icon">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M14 4H6a2 2 0 0 0-2 2v2"/><path d="M4 14h8a2 2 0 0 0 2-2v-2"/><polyline points="7,2 4,4 7,6"/><polyline points="11,16 14,14 11,12"/></svg>
            </div>
            <h3 class="bento-card__title">Loops and sub-workflows</h3>
            <p class="bento-card__desc">
              Iterative refinement with break conditions. Nest workflows as child steps. Hierarchical orchestration out of the box.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECTION 5: BEFORE / AFTER
         ═══════════════════════════════════════════ -->
    <section class="before-after section--standard" aria-labelledby="ba-heading">
      <div class="container">
        <div class="before-after__header" data-reveal>
          <span class="section-label">THE DIFFERENCE</span>
          <h2 id="ba-heading" class="section-title">Stop debugging agents in the dark.</h2>
        </div>

        <div class="before-after__grid" data-reveal-stagger>
          <div class="ba-panel ba-panel--before">
            <div class="ba-panel__label">Without Runsight</div>
            <ul class="ba-panel__list">
              <li>Agent workflows scattered across Python files</li>
              <li>No visibility into running agent decisions</li>
              <li>Debugging is printf and prayer</li>
              <li>Cost surprises after every batch run</li>
              <li>Three teams, three approaches, no shared patterns</li>
              <li>No eval — "looks good" is the test</li>
            </ul>
          </div>
          <div class="ba-panel ba-panel--after">
            <div class="ba-panel__label">With Runsight</div>
            <ul class="ba-panel__list">
              <li>Every workflow is a YAML file in Git</li>
              <li>Every block traced with cost and latency</li>
              <li>Visual canvas + YAML editor, same state</li>
              <li>Hard budget caps — kill before overspend</li>
              <li>One tool, one format, one Git history</li>
              <li>Assertions and regressions on every run</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECTION 6: HOW IT WORKS
         ═══════════════════════════════════════════ -->
    <section class="how-it-works section--standard" id="how-it-works" aria-labelledby="hiw-heading">
      <div class="container">
        <div class="how-it-works__header" data-reveal>
          <span class="section-label">HOW IT WORKS</span>
          <h2 id="hiw-heading" class="section-title">One command. Open your browser.</h2>
        </div>

        <div class="steps-grid" data-reveal-stagger>
          <div class="step-card">
            <span class="step-card__number">01</span>
            <h3 class="step-card__title">Run</h3>
            <p class="step-card__desc">One command. No signup. No cloud account. Scaffolds a project if none exists.</p>
            <div class="step-card__code"><span class="tk-punct">$</span> uvx runsight<br><span class="tk-cmt"># → localhost:8000</span></div>
          </div>
          <div class="step-card">
            <span class="step-card__number">02</span>
            <h3 class="step-card__title">Design</h3>
            <p class="step-card__desc">Write YAML in the editor or drag blocks on the canvas. Add your API key in the onboarding flow.</p>
            <div class="step-card__code"><span class="tk-cmt"># Your workflow is a file on disk</span><br>custom/workflows/my-flow.yaml</div>
          </div>
          <div class="step-card">
            <span class="step-card__number">03</span>
            <h3 class="step-card__title">Execute</h3>
            <p class="step-card__desc">Click Run. Watch blocks execute in real time. See cost accumulate per step.</p>
            <div class="step-card__code"><span class="tk-punct">▶</span> research  <span class="tk-str">$0.03</span>  1.2s<br><span class="tk-punct">▶</span> review    <span class="tk-str">$0.02</span>  0.8s</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECTION 7: FINAL CTA
         ═══════════════════════════════════════════ -->
    <section class="final-cta section--spacious" id="get-started" aria-labelledby="cta-heading" data-reveal>
      <div class="container">
        <h2 id="cta-heading" class="final-cta__headline">
          YAML workflows. Git-native.<br>Open source.
        </h2>
        <p class="final-cta__sub">Your workflows are YAML files in Git. If Runsight disappears, you still have readable config. No vendor lock-in by design.</p>
        <div class="final-cta__actions">
          <a href="#get-started" class="btn-install btn-lg"><span class="prompt">$</span> uvx runsight</a>
          <a href="https://github.com/runsight-ai/runsight" class="btn-ghost">View on GitHub</a>
          <a href="/docs/" class="btn-ghost">Read the docs</a>
        </div>
      </div>
    </section>

  </main>

  <!-- ═══════════════════════════════════════════
       FOOTER
       ═══════════════════════════════════════════ -->
  <footer class="footer">
    <div class="container">
      <div class="footer__grid">
        <div class="footer__brand">
          <a href="/" class="nav__logo" aria-label="Runsight home">
            <span class="nav__logo-mark">
              <svg viewBox="0 0 14 14" aria-hidden="true"><polygon points="3,2 12,7 3,12"/></svg>
            </span>
            Runsight
          </a>
          <p class="footer__brand-desc">
            YAML-first workflow engine for AI agents. Design, commit, run, evaluate.
          </p>
        </div>
        <div class="footer__column">
          <h3>Product</h3>
          <ul>
            <li><a href="#features">Features</a></li>
            <li><a href="#how-it-works">How It Works</a></li>
          </ul>
        </div>
        <div class="footer__column">
          <h3>Resources</h3>
          <ul>
