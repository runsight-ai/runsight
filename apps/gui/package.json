{
  "name": "runsight-gui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b",
    "build:bundle": "vite build",
    "preview": "vite preview",
    "lint": "pnpm run lint:colors && eslint .",
    "lint:colors": "rg -n \"#[0-9A-Fa-f]{3,8}\\b|rgba?\\(\" src --glob '!src/styles/globals.css' && (echo 'Hardcoded colors found outside src/styles/globals.css'; exit 1) || exit 0",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test": "playwright test",
    "generate:types": "bash ../../scripts/generate-types.sh",
    "check:types-fresh": "bash ../../scripts/check-types-fresh.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.62.0",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.0.1",
    "js-yaml": "^4.1.1",
    "openapi-typescript": "^7.13.0",
    "shadcn": "^4.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
